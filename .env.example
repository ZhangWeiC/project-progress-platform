# 首次生产启动必填，至少 12 位。现有数据库中仍为 123456 的账号也会被自动替换。
INITIAL_USER_PASSWORD=replace-with-a-strong-password

TZ=Asia/Shanghai

# 仅当前后端跨域部署时填写，多个来源使用英文逗号分隔。
CORS_ORIGIN=

# 飞书开放平台自建应用配置。
# 回调地址需要同时配置到飞书应用后台，例如本地开发：
# http://127.0.0.1:5173/auth/feishu/callback
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://127.0.0.1:5173/auth/feishu/callback
FEISHU_ROOT_DEPARTMENT_ID=0
FEISHU_DEFAULT_ROLE=worker
FEISHU_OAUTH_SCOPE=auth:user.id:read contact:user.base:readonly
